{
  "name": "emsmediasystem",
  "version": "6.5.1",
  "description": "A simple media player",
  "main": "derived/src/main.min.mjs",
  "scripts": {
    "start": "yarn build:parallel && electron .",
    "start-paid": "yarn build:parallel-paid && electron .",
    "build:source": "make -j app",
    "build:bible": "make -j bible",
    "build:bible-paid": "make -j bible-paid",
    "build:parallel": "concurrently --kill-others-on-fail --success all --names source,bible --prefix \"[{name}]\" \"make -j app\" \"make -j bible\"",
    "build:parallel-paid": "concurrently --kill-others-on-fail --success all --names source,bible --prefix \"[{name}]\" \"make -j app\" \"make -j bible-paid\"",
    "build": "make -j all",
    "build-paid": "make -j all-paid",
    "dist": "make -j all && electron-builder",
    "dist-win": "make -j all && electron-builder --win --publish=never",
    "dist-linux": "make -j all && electron-builder --linux --publish=never",
    "dist-all": "yarn build:parallel && concurrently \"electron-builder --win --publish=never\" \"electron-builder --linux --publish=never\"",
    "dist-all-paid": "yarn build:parallel-paid && concurrently \"electron-builder --win --publish=never\" \"electron-builder --linux --publish=never\"",
    "clean": "make clean"
  },
  "author": "Christian Lockley",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "csso": "^5.0.5",
    "electron": "^34.0.0",
    "electron-builder": "26.11.1",
    "esbuild": "^0.28.1",
    "html-minifier-terser": "^7.0.0",
    "terser": "^5.43.1"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.2.1",
    "dashjs": "^5.1.1",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "hls.js": "^1.6.16",
    "pdfjs-dist": "5.4.624",
    "write-file-atomic": "^7.0.0",
    "yauzl": "^3.3.2",
    "yazl": "^3.3.1",
    "youtubei.js": "^17.2.0",
    "zod": "^4.4.3"
  },
  "build": {
    "appId": "com.ejaxmediasystem.app",
    "productName": "EMS Media System",
    "afterPack": "scripts/verify-packaged-bible-assets.cjs",
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "!src/**/*",
      "!derived/src/*.map",
      "fonts/**/*",
      "node_modules/**/*",
      "index.prod.html",
      "derived/**/*",
      "!derived/bin/**/*",
      "!derived/bible/**/*",
      "!derived/**/*.wasm",
      "!derived/src/Bible.min.mjs",
      "!derived/src/wasm_exec.min.js",
      "!sidecars/**/*",
      "!private-bibles/**/*",
      "!build-artifacts/**/*",
      "!sidecars/**/*.json",
      "!sidecars/**/*autobackup*.tsv",
      "!**/bible-imports.json",
      "!**/import-bibles.mjs",
      "!index.html",
      "!**/*.map",
      "!build-artifacts",
      "!dist"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/icon.png",
      "fileAssociations": [
        {
          "ext": "emproj",
          "name": "EMS Project",
          "description": "EMS Media System Project",
          "role": "Editor"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "src/icon.png",
      "category": "Audio"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false
    },
    "extraResources": [
      {
        "from": "src/main.css",
        "to": ""
      },
      {
        "from": "derived/bin",
        "to": "bin"
      },
      {
        "from": "derived/bible",
        "to": "bible"
      }
    ]
  },
  "packageManager": "yarn@4.15.0"
}
