{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emsmediasystem.org/schemas/ems-slide.v1.json",
  "title": "EMS Slide Deck",
  "description": "Canonical EMS slide deck AST (schema ems.slideDeck.v1). Text objects reuse the same block/segment grammar as ems.song.v1.",
  "type": "object",
  "required": ["schema", "id", "title", "canvas", "pageSequence", "pages"],
  "properties": {
    "schema": { "const": "ems.slideDeck.v1" },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "folderId": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "safeMargins": {
          "type": "object",
          "properties": {
            "top": { "type": "number", "minimum": 0, "maximum": 1 },
            "right": { "type": "number", "minimum": 0, "maximum": 1 },
            "bottom": { "type": "number", "minimum": 0, "maximum": 1 },
            "left": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "theme": {
      "type": "object",
      "properties": {
        "fontFamily": { "type": "string" },
        "fontSize": { "type": "number" },
        "minFontSize": { "type": "number" },
        "autosizeMode": { "type": "string", "enum": ["fit", "normalize", "none"] },
        "textColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "backgroundPath": { "type": "string" },
        "transition": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "durationMs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "pages": {
      "type": "array",
      "description": "Page records keyed by id. Display/playback order is defined by pageSequence.",
      "items": { "$ref": "#/$defs/Page" }
    },
    "pageSequence": {
      "type": "array",
      "description": "Ordered page ids. Reordering slides changes this list, not the page records.",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "Page": {
      "type": "object",
      "required": ["id", "objects"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "autoAdvance": { "type": "boolean" },
        "transition": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "durationMs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "notes": { "type": "string" },
        "background": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["color", "image", "video"] },
            "color": { "type": "string" },
            "path": { "type": "string" },
            "assetId": { "type": "string" }
          },
          "additionalProperties": true
        },
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/Object" }
        }
      },
      "additionalProperties": true
    },
    "Object": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string", "enum": ["text", "image", "shape"] },
        "frame": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" }
          },
          "additionalProperties": true
        },
        "zIndex": { "type": "integer" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "autofit": { "type": "string", "enum": ["fit", "normalize", "none"] },
        "role": { "type": "string" },
        "style": {
          "type": "object",
          "properties": {
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "number" },
            "color": { "type": "string" },
            "align": { "type": "string", "enum": ["left", "center", "right"] },
            "verticalAlign": { "type": "string", "enum": ["top", "center", "bottom"] },
            "fontWeight": { "type": "string" },
            "lineHeight": { "type": "number" }
          },
          "additionalProperties": true
        },
        "background": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["color", "image", "video"] },
            "color": { "type": "string" },
            "path": { "type": "string" },
            "assetId": { "type": "string" }
          },
          "additionalProperties": true
        },
        "blocks": {
          "type": "array",
          "description": "EMS song text blocks (lyricLine/spacer/comment). Required when kind is 'text'.",
          "items": { "type": "object" }
        },
        "image": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "assetId": { "type": "string" },
            "fit": { "type": "string", "enum": ["cover", "contain", "fill"] }
          },
          "additionalProperties": true
        },
        "shape": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["rect", "ellipse", "line"] },
            "fill": { "type": "string" },
            "stroke": { "type": "string" },
            "strokeWidth": { "type": "number" },
            "radius": { "type": "number" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
